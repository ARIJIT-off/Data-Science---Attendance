# Copy this file to .env and fill in your values

# MongoDB Atlas connection string (optional)
# Get this from: cloud.mongodb.com -> Connect -> Connect your application
# If not set, the app will use local JSON files instead (good for local development)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/uemk_attendance?retryWrites=true&w=majority

# SMTP email credentials are loaded from mailmain.xlsx automatically
# You do NOT need to set these unless you want to override the Excel file
# SMTP_EMAIL=noreply.uemk.attendance@gmail.com
# SMTP_PASSWORD=your_app_password_here

# Server port (Railway/Render set this automatically)
PORT=3000
