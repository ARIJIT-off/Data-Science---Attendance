# Copy this file to .env for local development and fill in your values.
# On Railway, set these as environment variables in the service dashboard
# (Settings → Variables) — do NOT commit a real .env file to the repository.

# ---------------------------------------------------------------
# MongoDB Atlas connection string (REQUIRED for persistent storage)
# ---------------------------------------------------------------
# How to get this value:
#   1. Log in to https://cloud.mongodb.com
#   2. Click your cluster → "Connect" → "Drivers"
#   3. Copy the connection string and replace <password> with your DB user password
#
# On Railway: add MONGODB_URI as a service variable so the app connects to Atlas
# on every deploy.  Without this variable the app falls back to local JSON files,
# which are wiped on each Railway redeploy (ephemeral filesystem).
#
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/uemk_attendance?retryWrites=true&w=majority&appName=Cluster0

# ---------------------------------------------------------------
# SMTP credentials (loaded automatically from mailmain.xlsx)
# ---------------------------------------------------------------
# You do NOT need to set these unless you want to override the Excel file.
# SMTP_EMAIL=noreply.uemk.attendance@gmail.com
# SMTP_PASSWORD=your_app_password_here

# ---------------------------------------------------------------
# Server port — Railway and Render inject this automatically
# ---------------------------------------------------------------
PORT=3000
